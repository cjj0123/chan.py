# --- 兼容性数据结构定义 ---

class BacktestKLineUnit:
    """模拟 CChan/KLine 模块所需的 CKLine_Unit 结构。"""
    def __init__(self, timestamp: pd.Timestamp, open_p: float, high_p: float, low_p: float, close_p: float, volume: int, kl_type: KL_TYPE, original_klu: Any = None):
        self.timestamp = timestamp
        self.open = open_p
        self.high = high_p
        self.low = low_p
        self.close = close_p
        self.volume = volume
        self.kl_type = kl_type
        self.original_klu = original_klu # 用于保存原始K线对象（如果存在）
        
        # 适配 CTime 结构
        dt = timestamp.to_pydatetime()
        self.time = CTime(dt.year, dt.month, dt.day, dt.hour, dt.minute, dt.second, auto=False)
        
        # 简化处理，不包含复杂的父子K线关系，除非需要模拟CChan的load_iterator
        self.sup_kl = None
        self.sub_kl_list = []
        self.parent = None
        self.children = []
        self.idx = -1  # K 线索引
        self.pre_klu = None  # 前一根 K 线
        self.pre = None  # 前一根 K 线（CChan 兼容）
        self.next = None  # 后一根 K 线（CChan 兼容）
        self.macd = None  # MACD 指标（CChan 兼容）
        self.boll = None  # BOLL 指标（CChan 兼容）
        self.rsi = None  # RSI 指标（CChan 兼容）
        self.kdj = None  # KDJ 指标（CChan 兼容）
        self.demark = None  # Demark 指标（CChan 兼容）
        self.trend = {}  # 趋势指标（CChan 兼容）
        self.limit_flag = 0  # 涨跌停标志（CChan 兼容）
        self.trade_info = type('MockTradeInfo', (), {'metric': {}})()  # 交易信息（CChan 兼容）

    def set_idx(self, idx: int):
        """设置 K 线索引"""
        self.idx = idx
    
    def get_idx(self) -> int:
        """获取 K 线索引"""
        return self.idx
    
    def set_pre_klu(self, klu):
        """设置前一根 K 线（CChan 兼容的双向链接）"""
        self.pre_klu = klu
        self.pre = klu
        if klu is not None:
            klu.next = self
    
    def get_pre_klu(self):
        """获取前一根 K 线"""
        return self.pre_klu
    
    def set_metric(self, metric_model_lst: list) -> None:
        """设置技术指标（CChan 兼容版本）"""
        from Math.MACD import CMACD
        from Math.BOLL import BollModel
        from Math.RSI import RSI
        from Math.KDJ import KDJ
        from Math.Demark import CDemarkEngine
        from Math.TrendModel import CTrendModel
        
        for metric_model in metric_model_lst:
            try:
                if isinstance(metric_model, CMACD):
                    self.macd = metric_model.add(self.close)
                elif isinstance(metric_model, CTrendModel):
                    if metric_model.type not in self.trend:
                        self.trend[metric_model.type] = {}
                    self.trend[metric_model.type][metric_model.T] = metric_model.add(self.close)
                elif isinstance(metric_model, BollModel):
                    self.boll = metric_model.add(self.close)
                elif isinstance(metric_model, CDemarkEngine):
                    self.demark = metric_model.update(idx=self.idx, close=self.close, high=self.high, low=self.low)
                elif isinstance(metric_model, RSI):
                    self.rsi = metric_model.add(self.close)
                elif isinstance(metric_model, KDJ):
                    self.kdj = metric_model.add(self.high, self.low, self.close)
                elif hasattr(metric_model, 'add'):
                    metric_model.add(self.close)
            except Exception:
                pass  # 忽略计算错误
    
    def set_klc(self, klc):
        """设置 K 线组合引用（简化版本，用于回测）"""
        self.__klc = klc
    
    @property
    def klc(self):
        """获取 K 线组合引用（CChan 兼容）"""
        return self.__klc
    
    @property
    def klc(self):
        """获取 K 线组合引用（CChan 兼容）"""
        return self.__klc

    def __str__(self):
        return f"KLU({self.timestamp.strftime('%Y-%m-%d %H:%M')}, C:{self.close:.2f})"

class BacktestBroker:
    """
    模拟交易账户和经纪商，用于管理资金和持仓。
    """
    def __init__(self, initial_funds: float = 100000.0, lot_size_map: Dict[str, int] = None):
        self.initial_funds = initial_funds
        self.available_funds = initial_funds
        self.positions: Dict[str, Dict[str, Any]] = {}  # {code: {'qty': 1000, 'avg_price': 10.5}}
        self.trades: List[Dict[str, Any]] = []
        self.lot_size_map = lot_size_map if lot_size_map is not None else {}
        self.default_lot_size = 100
        self.transaction_cost_rate = 0.001  # 假设万分之1的交易成本 (买卖双边)

    def get_lot_size(self, code: str) -> int:
        return self.lot_size_map.get(code, self.default_lot_size)

    def get_position_quantity(self, code: str) -> int:
        return self.positions.get(code, {}).get('qty', 0)

    def calculate_position_size(self, code: str, current_price: float, max_investment_ratio: float = 0.2) -> int:
        """计算可买入的数量，并确保是整数手。"""
        if current_price <= 0:
            return 0
            
        max_investment = self.available_funds * max_investment_ratio
        lot_size = self.get_lot_size(code)
        
        shares_to_buy = int(max_investment / current_price)
        
        # 取整到最小的整手
        final_quantity = (shares_to_buy // lot_size) * lot_size
        
        return max(0, final_quantity)

    def execute_trade(self, code: str, action: str, quantity: int, price: float, timestamp: pd.Timestamp) -> bool:
        """执行模拟交易"""
        if quantity <= 0:
            return False
        
        lot_size = self.get_lot_size(code)
        if quantity % lot_size != 0:
            logging.warning(f"Trade quantity {quantity} for {code} is not a multiple of lot size {lot_size}. Adjusting.")
            quantity = (quantity // lot_size) * lot_size
            if quantity == 0: return False

        cost = price * quantity * self.transaction_cost_rate
        
        if action.upper() == 'BUY':
            required_funds = price * quantity + cost
            if self.available_funds < required_funds:
                logging.warning(f"BUY {code}: 资金不足。需要 {required_funds:.2f}, 拥有 {self.available_funds:.2f}")
                return False
            
            self.available_funds -= required_funds
            
            # 更新持仓
            if code not in self.positions:
                self.positions[code] = {'qty': 0, 'avg_price': 0.0}
            
            old_qty = self.positions[code]['qty']
            new_qty = old_qty + quantity
            old_cost = old_qty * self.positions[code]['avg_price']
            new_avg_price = (old_cost + price * quantity) / new_qty if new_qty > 0 else price
            
            self.positions[code]['qty'] = new_qty
            self.positions[code]['avg_price'] = new_avg_price
            
            self.trades.append({
                'time': timestamp, 'code': code, 'action': 'BUY', 'qty': quantity, 
                'price': price, 'cost': cost, 'funds_after': self.available_funds
            })
            logging.info(f"BUY {code}: Qty={quantity}, Price={price:.3f}, Cost={cost:.2f}")
            return True
            
        elif action.upper() == 'SELL':
            if self.get_position_quantity(code) < quantity:
                logging.warning(f"SELL {code}: 持仓不足 {quantity} 股，当前持仓 {self.get_position_quantity(code)}")
                return False
            
            self.available_funds -= cost # 卖出也产生成本（佣金/印花税等）
            
            # 更新持仓
            self.positions[code]['qty'] -= quantity
            if self.positions[code]['qty'] == 0:
                del self.positions[code]
            
            self.trades.append({
                'time': timestamp, 'code': code, 'action': 'SELL', 'qty': quantity, 
                'price': price, 'cost': cost, 'funds_after': self.available_funds
            })
            logging.info(f"SELL {code}: Qty={quantity}, Price={price:.3f}, Cost={cost:.2f}")
            return True
            
        return False

    def get_final_performance(self, end_time: pd.Timestamp) -> Dict[str, Any]:
        """计算最终绩效"""
        # 1. 卖出所有剩余持仓（以收盘价计算）
        final_value = self.available_funds
        for code, pos in self.positions.items():
            # 假设我们获取到了此时的收盘价，这里用最后一个K线的收盘价作为清算价
            # 实际回测中需要当前K线的收盘价或下一根K线的开盘价
            # 为简化，此处使用该仓位的平均成本价作为清算价（会高估/低估，需在步骤5中改进）
            # 暂时使用平均成本价作为清算价，并在报告中说明
            final_value += pos['qty'] * pos['avg_price']

        total_return = (final_value - self.initial_funds) / self.initial_funds
        
        return {
            'initial_funds': self.initial_funds,
            'final_cash': self.available_funds,
            'final_portfolio_value': final_value,
            'total_return_pct': total_return,
            'final_positions': self.positions,
            'trades_count': len(self.trades)
        }

# --- DataLoader 保持不变，但引入 BacktestKLineUnit ---
class BacktestDataLoader:
    """
    负责从 stock_cache 目录加载 Parquet 格式的历史K线数据，并转换为适合
    CChan/strategy 模块使用的 KLine 结构列表。
    """
    
    def __init__(self, cache_dir: str = "stock_cache"):
        self.cache_dir = cache_dir
        self.logger = logging.getLogger(__name__ + ".DataLoader")

    def _find_data_file(self, code: str, freq: str) -> Optional[str]:
        """尝试在缓存目录中找到匹配的文件路径。"""
        if freq.upper() in ("30M", "30MIN"): freq_suffix = "30M"
        elif freq.upper() in ("5M", "5MIN"): freq_suffix = "5M"
        elif freq.upper() in ("DAY", "D"): freq_suffix = "DAY"
        else: freq_suffix = freq.upper()

        possible_patterns = [
            f"{code}_K_{freq_suffix}.parquet",
            f"{code}_k_{freq_suffix}.parquet",
        ]
        
        for pattern in possible_patterns:
            file_path = os.path.join(self.cache_dir, pattern)
            if os.path.exists(file_path):
                return file_path
        
        self.logger.warning(f"未找到 {code} 的 {freq} 频率数据文件在 {self.cache_dir}/")
        return None

    def _parse_parquet_to_kline_list(self, df: pd.DataFrame, freq: str) -> List[BacktestKLineUnit]:
        """将加载的 DataFrame 转换为回测引擎所需的 KLine 结构列表。"""
        kline_list: List[BacktestKLineUnit] = []
        
        time_col = None
        ohlcv_cols: Dict[str, str] = {}
        lower_cols = {c.lower(): c for c in df.columns}
        
        # 推断时间列
        if 'time' in lower_cols: time_col = lower_cols['time']
        elif 'time_key' in lower_cols: time_col = lower_cols['time_key']
        elif 'timestamp' in lower_cols: time_col = lower_cols['timestamp']
        elif df.index.dtype.kind in 'mMU': time_col = 'index'

        # 推断 OHLCV 列
        for field, lower_name in [('open', 'open'), ('high', 'high'), ('low', 'low'), ('close', 'close'), ('volume', 'volume'), ('vol', 'vol')]:
            if lower_name in lower_cols:
                ohlcv_cols[field] = lower_cols[lower_name]
        
        if not time_col or not all(c in ohlcv_cols for c in ['open', 'high', 'low', 'close']):
            self.logger.error("无法自动识别 DataFrame 中的时间或 OHLC 列名。")
            return []

        if time_col != 'index':
            df = df.sort_values(by=time_col)

        kl_type_map = {"30M": KL_TYPE.K_30M, "5M": KL_TYPE.K_5M, "DAY": KL_TYPE.K_DAY}
        target_kl_type = kl_type_map.get(freq.upper(), KL_TYPE.K_DAY) 

        for index, row in df.iterrows():
            try:
                if time_col == 'index':
                    ts = index
                else:
                    ts = row[time_col]
                    if isinstance(ts, CTime):
                        ts = pd.Timestamp.fromtimestamp(ts.ts)
                    elif isinstance(ts, (int, float)):
                        ts = pd.to_datetime(ts, unit='s')
                    elif isinstance(ts, str):
                        ts = pd.to_datetime(ts)
                
                if not isinstance(ts, pd.Timestamp): continue

                klu = BacktestKLineUnit(
                    timestamp=ts,
                    open_p=float(row[ohlcv_cols['open']]),
                    high_p=float(row[ohlcv_cols['high']]),
                    low_p=float(row[ohlcv_cols['low']]),
                    close_p=float(row[ohlcv_cols['close']]),
                    volume=int(row.get(ohlcv_cols.get('volume', 'volume'), 0)), 
                    kl_type=target_kl_type,
                    original_klu=row # 暂时保存原始行数据
                )
                kline_list.append(klu)
            except Exception as e:
                self.logger.error(f"转换单根K线时出错: {e}")
                continue
        
        self.logger.info(f"成功将 {len(kline_list)} 根 K 线转换为回测格式 (Freq: {freq})")
        return kline_list

    def load_kline_data(self, code: str, freq: str, start_date: Optional[str] = None, end_date: Optional[str] = None) -> Optional[List[BacktestKLineUnit]]:
        """
        加载指定股票和频率的历史K线数据，并转换为 BacktestKLineUnit 列表。
        """
        file_path = self._find_data_file(code, freq)
        
        if not file_path:
            return None
        
        self.logger.info(f"成功找到数据文件: {file_path}")

        try:
            df = pd.read_parquet(file_path)
        except Exception as e:
            self.logger.error(f"读取 Parquet 文件 {file_path} 失败: {e}")
            return None

        kline_units = self._parse_parquet_to_kline_list(df, freq)
        kline_units.sort(key=lambda x: x.timestamp)
            
        filtered_list = []
        start_ts = pd.to_datetime(start_date) if start_date else pd.Timestamp.min
        end_ts = pd.to_datetime(end_date) if end_date else pd.Timestamp.max
        
        for klu in kline_units:
            if start_ts <= klu.timestamp <= end_ts:
                filtered_list.append(klu)
            
        if not filtered_list:
            self.logger.warning(f"数据加载后为空。请检查日期范围: {start_date} 至 {end_date}")
            return None
            
        self.logger.info(f"{code} {freq} 数据加载成功，共 {len(filtered_list)} 条记录。")
        return filtered_list

# --- 策略/信号生成适配器 (用于替代 live trading logic) ---

class BacktestStrategyAdapter:
    """
    适配 live trading 逻辑到回测环境。
    回测需要的是一个函数，输入 K 线数据，输出信号 (BUY/SELL/WAIT)。
    """
    def __init__(self, live_trader_instance: Any, chan_config: CChanConfig):
        # 尝试复制或加载 live trader 的关键组件和配置
        self.live_trader = live_trader_instance
        self.chan_config = chan_config
        self.logger = logging.getLogger(__name__ + ".StrategyAdapter")
        
        # 由于无法直接复制整个 Trader 实例，我们需要模拟其分析能力
        # 关键是获取CChan实例，并利用其分析能力
        
    def _prepare_chan_instance(self, code: str, klines: List[BacktestKLineUnit], freq: str) -> Optional[CChan]:
        """
        根据历史K线列表，构建 CChan 实例，以模拟其分析过程。
        
        注意: CChan.load() 依赖 API，因此我们需要模拟数据输入而不是调用 API。
        这里我们假设可以创建一个简化的 CChan 实例来处理 KLU 列表。
        **这是回测适配中最复杂、最脆弱的部分。**
        """
        if not CChan:
            self.logger.error("CChan 未导入，无法进行策略分析。")
            return None

        # 1. 确定频率级别
        freq_map = {"30M": KL_TYPE.K_30M, "5M": KL_TYPE.K_5M, "DAY": KL_TYPE.K_DAY}
        target_kl_type = freq_map.get(freq.upper(), KL_TYPE.K_30M)
        
        # 2. 构造一个 CChan 实例，并注入历史数据
        # 这一步需要对 CChan 的内部结构有深入了解。鉴于 CChan.load() 依赖 API，
        # 我们必须使用 trigger_step 模式，并手动提供数据。
        
        # 创建一个模拟的 DataAPI/StockAPI 实例，使其返回我们准备好的 KLU 列表
        class MockStockAPI:
            def __init__(self, klu_list: List[BacktestKLineUnit], kl_type: KL_TYPE):
                # 过滤出指定级别的 KLU，并按照 CChan 的期望排序
                self.klu_list = [klu for klu in klu_list if klu.kl_type == kl_type]
                self.klu_list.sort(key=lambda x: x.timestamp)
                self._iter = iter(self.klu_list)
                self.kl_type = kl_type
                self.code = code
                self.autype = 0 # 0 for QFQ
                
            def get_kl_data(self) -> Iterator[BacktestKLineUnit]:
                """模拟 API 返回K线迭代器"""
                return self._iter

            @classmethod
            def do_init(cls): pass
            @classmethod
            def do_close(cls): pass

        # 3. 实例化 CChan 并使用 trigger_step 模式加载
        # 导入 MockStockAPI 的注册函数
        from DataAPI.MockStockAPI import register_kline_data
        
        # 注册 K 线数据到全局注册表
        register_kline_data(code, target_kl_type, klines)
        
        chan_instance = CChan(
            code=code,
            data_src="custom:MockStockAPI.MockStockAPI",
            lv_list=[target_kl_type],
            config=self.chan_config,
            autype=0,
            begin_time=None,
            end_time=None
        )
        
        # 运行触发式加载
        # 必须确保 CChanConfig.trigger_step 为 True 才能进入此流程
        if not chan_instance.conf.trigger_step:
            chan_instance.conf.trigger_step = True
            chan_instance.conf.skip_step = 0

        # 运行加载，这会填充 chan_instance.kl_datas
        try:
            for _ in chan_instance.step_load():
                pass
        except Exception as e:
            self.logger.error(f"{code} {freq} 策略分析时构建 CChan 失败: {e}")
            return None
            
        return chan_instance

    def get_signal(self, code: str, klines_by_freq: Dict[str, List[BacktestKLineUnit]], lot_size_map: Dict[str, int]) -> Optional[Dict]:
        """
        核心分析函数。对于每支股票，我们需要多个时间级别的 K 线来生成信号。
        我们模仿 live trading 逻辑，主要依赖 30M 信号，并使用 5M/DAY 辅助。
        """
        
        # 目标：获取最新的买卖点 (BSP)
        
        # 1. 准备 K 线数据
        # 假设我们只使用 30M (主要) 和 5M (辅助) 来判断信号，并使用 DAY 来判断趋势/过滤
        
        klines_30m = klines_by_freq.get("30M")
        klines_5m = klines_by_freq.get("5M")
        klines_day = klines_by_freq.get("DAY")
        
        if not klines_30m or not klines_30m: # 至少需要30M数据
            self.logger.warning(f"{code}: 缺少关键的 30M/5M 数据，跳过分析。")
            return None

        # 2. 模拟 CChan 实例的生成过程 (需要获取到 CChan 实例)
        
        # 对于回测，我们通常使用 KLine 列表构建一个“历史”的 CChan 实例
        # 为了简化，我们假设策略分析的核心只需要最后一个 KLU 对象作为“当前”K线
        
        # 关键点：CChan 依赖于连续的K线计算。我们必须将历史数据按级别构建 CChan。
        
        chan_multi_level: List[CChan] = []
        
        try:
            # 构建 30M 级别 CChan
            chan_30m = self._prepare_chan_instance(code, klines_30m, "30M")
            if chan_30m:
                chan_multi_level.append(chan_30m)
            
            # 构建 5M 级别 CChan (如果数据存在)
            if klines_5m:
                chan_5m = self._prepare_chan_instance(code, klines_5m, "5M")
                if chan_5m:
                    # 注意：这里是模仿 live trader 的结构，但实际的 K 线关联性需要 CChan 内部处理
                    chan_multi_level.append(chan_5m)
            
        except Exception as e:
            self.logger.error(f"构建 CChan 实例失败 for {code}: {e}")
            return None

        if not chan_multi_level:
            return None
            
        # 3. 获取最新买卖点 (模仿 analyze_with_chan 的核心逻辑)
        # live trader 默认使用第一个级别 (即 30M) 的最新 BSP
        chan_main = chan_multi_level[0]
        
        try:
            latest_bsps = chan_main.get_latest_bsp(number=1)
        except Exception as e:
            self.logger.error(f"获取 {code} 最新 BSP 失败: {e}")
            return None

        if not latest_bsps:
            return None
        
        bsp = latest_bsps[0]
        bsp_type = bsp.type2str()
        is_buy = bsp.is_buy
        price = bsp.klu.close # 使用当前K线的收盘价作为信号价格
        bsp_time = bsp.klu.time # CTime 对象

        # 4. 过滤：时间窗口过滤 (回测中需要模拟"当前时间")
        # 在回测中，我们通常只需要最新的信号即可，不需要时间衰减，
        # 但为了兼容，我们假设“当前时间”是所有 K 线中的最后一个时间点。
        current_time_pd = klines_30m[-1].timestamp
        
        # 简化处理：不进行时间衰减过滤，只要有信号就保留
        
        result = {
            'code': code,
            'is_buy': is_buy,
            'bsp_type': bsp_type,
            'signal_price': price,
            'signal_time': current_time_pd, # Pandas Timestamp
            'lot_size': lot_size_map.get(code, 100),
            'chan_analysis': {
                'chan_multi_level': chan_multi_level, # 携带 CChan 实例用于图表生成
                'bsp_instance': bsp
            }
        }
        
        self.logger.info(f"{code} 策略分析: 发现 {bsp_type} 信号, 价格: {price}")
        return result

    # 假设我们不需要视觉评分，因为那是针对实时截图的。
    # 在回测中，我们直接使用缠论信号本身作为“原始信号”，并跳过视觉评分步骤 (Todo 5, 6部分修改)。
    def evaluate_signal_for_backtest(self, signal: Dict) -> Dict:
        """
        在回测中，我们不再需要视觉评分。信号的“评分”就是缠论信号本身。
        """
        signal['score'] = 99 # 给予高分，表示通过了“策略判断”，但尚未执行交易
        signal['is_valid_for_trade'] = True
        
        # 确保有图表路径字段，即使我们不生成它们，以匹配后续流程
        if 'chart_paths' not in signal:
             signal['chart_paths'] = []
             
        return signal


# --- DataLoader 的封装，用于在回测主循环中迭代数据 ---

class BacktestDataIterator:
    def __init__(self, loader: BacktestDataLoader, watchlist: List[str], freq: str, start_date: str, end_date: str):
        self.loader = loader
        self.watchlist = watchlist
        self.freq = freq
        self.start_date = start_date
        self.end_date = end_date
        self.data_cache: Dict[str, List[BacktestKLineUnit]] = {}
        self._load_all_data()
        
        # 确定回测的整体时间轴 (取所有数据的最早和最晚时间)
        all_times = [klu.timestamp for klu_list in self.data_cache.values() for klu in klu_list]
        self.timeline = sorted(list(set(all_times)))
        
        self.current_index = 0
        self.max_index = len(self.timeline)

    def _load_all_data(self):
        """预加载所有股票在指定时间范围内的所有频率数据"""
        self.logger = logging.getLogger(__name__ + ".Iterator")
        
        # 确定需要加载的频率（基于 live trader 的分析需求）
        required_freqs = ["30M", "5M", "DAY"] 
        
        for code in self.watchlist:
            self.data_cache[code] = {}
            all_freq_loaded = True
            for freq in required_freqs:
                data = self.loader.load_kline_data(code, freq, self.start_date, self.end_date)
                if data:
                    self.data_cache[code][freq] = data
                else:
                    self.logger.warning(f"未能加载 {code} 的 {freq} 数据，该股票的分析可能会跳过或失败。")
                    all_freq_loaded = False
            
            if not all_freq_loaded and code in self.data_cache:
                 # 如果关键数据缺失，则标记该股票为不可用
                 self.data_cache[code]['__AVAILABLE__'] = False
            else:
                 self.data_cache[code]['__AVAILABLE__'] = True

    def __iter__(self) -> Iterator[Tuple[pd.Timestamp, Dict[str, Any]]]:
        """
        迭代器返回 (current_timestamp, data_snapshot_at_that_time)
        data_snapshot: {code: list_of_klines_up_to_this_time}
        """
        current_index = 0
        while current_index < self.max_index:
            current_time = self.timeline[current_index]
            snapshot: Dict[str, Any] = {}
            
            for code in self.watchlist:
                if not self.data_cache[code].get('__AVAILABLE__', False):
                    continue
                    
                # 收集当前时间点之前的所有K线，并确保它们都按级别分组
                klines_at_time = {freq: [] for freq in ["30M", "5M", "DAY"]}
                
                for freq, kline_list in self.data_cache[code].items():
                    if freq.startswith('_'): continue
                    
                    # 找到所有时间戳 <= current_time 的 K 线
                    # 注意：由于K线是固定时间的块，我们只需找到时间戳小于等于当前时间点的最后一根K线
                    
                    # 优化：找到第一个 timestamp > current_time 的 K 线的索引
                    
                    # 线性查找（对于大数据集可能慢，但在迭代器中可接受）
                    valid_klines = [klu for klu in kline_list if klu.timestamp <= current_time]
                    
                    if valid_klines:
                        # 只有最新的一根K线才被策略视为“当前K线”
                        latest_klu = valid_klines[-1]
                        klines_at_time[freq] = [latest_klu] # CChan.load_iterator 期望的是一个包含 KLU 的迭代器/列表
                        
                    if kline_list:
                        # 确保时间轴覆盖到当前时间点
                        if current_time < kline_list[0].timestamp or current_time > kline_list[-1].timestamp:
                             # 股票数据没有覆盖到当前时间点，跳过该股票
                             continue 

                # 只有当所有关键频率（30M, 5M）都至少有一根K线时，才将该股票加入快照
                if klines_at_time.get("30M") and klines_at_time.get("5M"):
                     snapshot[code] = klines_at_time

            yield current_time, snapshot
            current_index += 1

# --- 结束 ---
