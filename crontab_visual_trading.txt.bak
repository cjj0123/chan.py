# 缠论视觉增强交易系统定时任务配置
# 请确保在执行前设置好环境变量

# 设置环境变量（需要在shell配置文件中设置或在此处显式设置）
# GOOGLE_API_KEY=your_actual_api_key_here
# REAL_TRADING=false  # 设为true启用实盘交易

# 每个交易日的指定时间运行交易系统
# 早上9:30开市前分析
00 09 * * 1-5 source ~/.bashrc && cd /path/to/your/trading/system && python3 futu_sim_trading_enhanced.py >> /var/log/trading_system.log 2>&1

# 上午11:00再次分析
00 11 * * 1-5 source ~/.bashrc && cd /path/to/your/trading/system && python3 futu_sim_trading_enhanced.py >> /var/log/trading_system.log 2>&1

# 下午1:30开市后分析
30 13 * * 1-5 source ~/.bashrc && cd /path/to/your/trading/system && python3 futu_sim_trading_enhanced.py >> /var/log/trading_system.log 2>&1

# 下午3:00收盘前分析
00 15 * * 1-5 source ~/.bashrc && cd /path/to/your/trading/system && python3 futu_sim_trading_enhanced.py >> /var/log/trading_system.log 2>&1

# 每天晚上更新系统日志
00 23 * * * find /var/log -name "trading_system.log" -size +100M -exec gzip {} \;