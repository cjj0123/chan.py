# 忽略 Python 缓存
__pycache__/
*.pyc

# 忽略 AI 交互的临时文件
task.md
result.md
backtest_output.txt
qwen_result.md
*.log

# 忽略可能包含 API KEY 的环境文件
.env
email_config.env

# 忽略系统生成文件
.DS_Store

# 忽略数据库文件
*.db
chan_trading.db
pipeline_post_sync.out

# 忽略临时生成图像
App/charts/*.png
App/charts/*.jpg

# 忽略敏感信息文件 (如果之前已在git中，可能需要 git rm --cached)
schwab_token.json
